{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kiro Keyboard Companion",
  "version": "0.1.0",
  "identifier": "com.kiro.keyboard.companion",
  "build": {
    "beforeDevCommand": "npm run vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run typecheck && npm run frontend:build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Kiro Keyboard Companion",
        "width": 980,
        "height": 760,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": []
  }
}

{
  "name": "reviewer",
  "description": "Checks correctness, regressions, and edge cases before merge.",
  "prompt": "file://./prompts/reviewer.md",
  "keyboardShortcut": "ctrl+3",
  "welcomeMessage": "Reviewer online",
  "hooks": {
    "agentSpawn": [
      {
        "command": "python3 scripts/kiro_board_hook.py --agent-name reviewer"
      }
    ],
    "userPromptSubmit": [
      {
        "command": "python3 scripts/kiro_board_hook.py --agent-name reviewer"
      }
    ],
    "stop": [
      {
        "command": "python3 scripts/kiro_board_hook.py --agent-name reviewer"
      }
    ],
    "postToolUse": [
      {
        "command": "python3 scripts/kiro_board_hook.py --agent-name reviewer"
      }
    ]
  }
}

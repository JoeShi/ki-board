{
  "name": "planner",
  "description": "Plans work, decomposes tasks, and asks for missing context before implementation.",
  "prompt": "file://./prompts/planner.md",
  "keyboardShortcut": "ctrl+1",
  "welcomeMessage": "Planner online",
  "hooks": {
    "agentSpawn": [
      {
        "command": "python3 scripts/kiro_board_hook.py --agent-name planner --serial-port /dev/cu.usbmodem14C19F35A9082"
      }
    ],
    "userPromptSubmit": [
      {
        "command": "python3 scripts/kiro_board_hook.py --agent-name planner --serial-port /dev/cu.usbmodem14C19F35A9082"
      }
    ],
    "stop": [
      {
        "command": "python3 scripts/kiro_board_hook.py --agent-name planner --serial-port /dev/cu.usbmodem14C19F35A9082"
      }
    ],
    "postToolUse": [
      {
        "command": "python3 scripts/kiro_board_hook.py --agent-name planner --serial-port /dev/cu.usbmodem14C19F35A9082"
      }
    ]
  }
}

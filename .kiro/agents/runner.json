{
  "name": "runner",
  "description": "Executes commands, build steps, and validation loops.",
  "prompt": "file://./prompts/runner.md",
  "keyboardShortcut": "ctrl+4",
  "welcomeMessage": "Runner online",
  "hooks": {
    "agentSpawn": [
      {
        "command": "python3 scripts/kiro_board_hook.py --agent-name runner --serial-port /dev/cu.usbmodem14C19F35A9082"
      }
    ],
    "userPromptSubmit": [
      {
        "command": "python3 scripts/kiro_board_hook.py --agent-name runner --serial-port /dev/cu.usbmodem14C19F35A9082"
      }
    ],
    "stop": [
      {
        "command": "python3 scripts/kiro_board_hook.py --agent-name runner --serial-port /dev/cu.usbmodem14C19F35A9082"
      }
    ],
    "postToolUse": [
      {
        "command": "python3 scripts/kiro_board_hook.py --agent-name runner --serial-port /dev/cu.usbmodem14C19F35A9082"
      }
    ]
  }
}
